#!/usr/bin/env bash
set -e
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" >/dev/null && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")/.." >/dev/null && pwd)"

seed_kernel_workspace() {
  local linux_volume sync_container_id kernel_rev

  linux_volume="vamos-kernel-linux"
  kernel_rev="$(git -C "$DIR/kernel/linux" rev-parse HEAD)"

  echo "Syncing kernel/linux into Docker volume"
  sync_container_id=$(docker run -d --entrypoint tail -v "$linux_volume:/linux" vamos-builder -f /dev/null)

  docker exec "$sync_container_id" sh -lc "rm -rf /linux/* /linux/.[!.]* /linux/..?*"

  tar -C "$DIR/kernel/linux" -cf - . | docker exec -i "$sync_container_id" tar -xf - -C /linux
  docker exec "$sync_container_id" sh -lc "printf '%s\n' '$kernel_rev' > /linux/.vamos-kernel-rev"
  docker container rm -f "$sync_container_id" >/dev/null
}

ensure_builder_image() {
  if ! docker image inspect vamos-builder >/dev/null 2>&1; then
    echo "Building vamos-builder docker image"
    export DOCKER_BUILDKIT=1
    docker build -f tools/build/Dockerfile.builder -t vamos-builder "$DIR" \
      --build-arg UNAME="$(id -nu)" \
      --build-arg UID="$(id -u)" \
      --build-arg GID="$(id -g)"
  fi
}

collect_kernel_profile_from_volume() {
  local linux_volume output_dir

  linux_volume="vamos-kernel-linux"
  output_dir=${1:-"$DIR/build"}

  ensure_builder_image

  if ! docker volume inspect "$linux_volume" >/dev/null 2>&1; then
    echo "Missing Docker volume $linux_volume. Run ./vamos setup or ./vamos build kernel first."
    exit 1
  fi

  mkdir -p "$output_dir"

  docker run --rm \
    --entrypoint bash \
    -u "$(id -u):$(id -g)" \
    -v "$DIR:$DIR" \
    -v "$linux_volume:/linux" \
    -w "$DIR" \
    vamos-builder \
    "$DIR/tools/profile/kernel.sh" collect /linux/out "$output_dir"
}

setup() {
  git -C "$DIR" submodule update --init --depth 1
  if [ "$(uname)" = "Darwin" ]; then
    ensure_builder_image
    docker volume create "vamos-kernel-linux" >/dev/null
    seed_kernel_workspace
  fi
  if [ "$(uname)" = "Linux" ]; then
    UDEV_RULES="/etc/udev/rules.d/99-qualcomm-edl.rules"
    if [ ! -f "$UDEV_RULES" ]; then
      echo "Setting up udev rules for Qualcomm EDL..."
      sudo tee "$UDEV_RULES" > /dev/null <<'EOF'
SUBSYSTEM=="usb", ATTR{idVendor}=="05c6", ATTR{idProduct}=="9008", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="3801", ATTR{idProduct}=="9008", MODE="0666"
EOF
      sudo udevadm trigger --attr-match=subsystem=usb
    fi
  fi
}

case "${1:-}" in
  setup)    setup ;;
  build)
    case "${2:-}" in
      kernel) exec "$DIR/tools/build/build_kernel.sh" ;;
      system) exec "$DIR/tools/build/build_system.sh" ;;
      *)      echo "Usage: vamos build <kernel|system>"; exit 1 ;;
    esac ;;
  flash)
    case "${2:-}" in
      kernel)   exec "$DIR/tools/flash/kernel.sh" "${3:-}" ;;
      system)   exec "$DIR/tools/flash/system.sh" ;;
      firmware) exec "$DIR/tools/flash/firmware.sh" ;;
      gpt)      exec "$DIR/tools/flash/gpt.sh" ;;
      all)      "$DIR/tools/flash/gpt.sh" && "$DIR/tools/flash/firmware.sh" && "$DIR/tools/flash/kernel.sh" && "$DIR/tools/flash/system.sh" ;;
      *)        echo "Usage: vamos flash <kernel|system|firmware|gpt|all>"; exit 1 ;;
    esac ;;
  profile)
    shift
    case "${1:-}" in
      kernel)
        shift
        case "${1:-}" in
          ""|collect)
            if [ "$#" -le 1 ]; then
              if [ "$(uname)" = "Darwin" ]; then
                collect_kernel_profile_from_volume "$DIR/build"
                exit 0
              fi
              exec bash "$DIR/tools/profile/kernel.sh" collect "$DIR/kernel/linux/out" "$DIR/build"
            fi
            shift
            if [ "$(uname)" = "Darwin" ] && [ "$#" -eq 1 ]; then
              collect_kernel_profile_from_volume "$1"
              exit 0
            fi
            exec bash "$DIR/tools/profile/kernel.sh" collect "$@" ;;
          diff)
            shift
            exec bash "$DIR/tools/profile/kernel.sh" diff "$@" ;;
          *)
            exec bash "$DIR/tools/profile/kernel.sh" "$@" ;;
        esac ;;
      ""|diff)
        exec "$DIR/tools/profile/rootfs.sh" "$@" ;;
      *)
        exec "$DIR/tools/profile/rootfs.sh" "$@" ;;
    esac ;;
  *)
    echo "Usage: vamos <setup|build|flash|profile>"
    echo ""
    echo "  setup              Initialize submodules and udev rules"
    echo "  build kernel       Build the kernel (output/boot.img)"
    echo "  build system       Build the system image (output/system.img)"
    echo "  flash kernel       Flash boot.img to device via EDL (--legacy for legacy kernel)"
    echo "  flash system       Flash system.img to device via EDL"
    echo "  flash firmware     Flash firmware partitions to device via EDL"
    echo "  flash gpt          Flash GPT partition tables to device via EDL"
    echo "  flash all          Flash gpt + firmware + kernel + system"
    echo "  profile            Collect a rootfs profile"
    echo "  profile diff <baseline_json> <current_json>"
    echo "                     Diff two rootfs profiles"
    echo "  profile kernel [out_dir output_dir]"
    echo "                     Collect a kernel profile. On macOS with the Docker volume"
    echo "                     workflow, this reads /linux/out from the volume and writes"
    echo "                     into build/ by default without rebuilding. On Linux,"
    echo "                     it collects from kernel/linux/out into build/ by default."
    echo "  profile kernel diff <baseline_json> <current_json>"
    echo "                     Diff two kernel profiles"
    exit 1 ;;
esac
