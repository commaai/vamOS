+/* --- Userspace register control ioctls --- */
+
+#include <linux/dma-buf.h>
+#include <uapi/linux/qcom-camss-vfe.h>
+
+static long vfe_17x_write_regs(struct vfe_device *vfe, void __user *arg)
+{
+	struct vfe_write_regs_cmd *cmd = arg;
+	struct vfe_reg_write *regs;
+	int i, ret = 0;
+
+	if (cmd->count == 0 || cmd->count > 1024)
+		return -EINVAL;
+
+	regs = kvmalloc_array(cmd->count, sizeof(*regs), GFP_KERNEL);
+	if (!regs)
+		return -ENOMEM;
+
+	if (copy_from_user(regs, u64_to_user_ptr(cmd->regs),
+			   cmd->count * sizeof(*regs))) {
+		ret = -EFAULT;
+		goto out;
+	}
+
+	for (i = 0; i < cmd->count; i++) {
+		if (regs[i].offset >= VFE_REG_SPACE_SIZE) {
+			ret = -EINVAL;
+			goto out;
+		}
+		writel_relaxed(regs[i].value, vfe->base + regs[i].offset);
+	}
+	wmb();
+
+out:
+	kvfree(regs);
+	return ret;
+}
+
+static long vfe_17x_write_dmi(struct vfe_device *vfe, void __user *arg)
+{
+	struct vfe_dmi_cmd *cmd = arg;
+	u32 *data;
+	int i, ret = 0;
+
+	if (cmd->count == 0 || cmd->count > 4096)
+		return -EINVAL;
+
+	if (cmd->dmi_cfg_offset >= VFE_REG_SPACE_SIZE)
+		return -EINVAL;
+
+	data = kvmalloc_array(cmd->count, sizeof(*data), GFP_KERNEL);
+	if (!data)
+		return -ENOMEM;
+
+	if (copy_from_user(data, u64_to_user_ptr(cmd->data),
+			   cmd->count * sizeof(*data))) {
+		ret = -EFAULT;
+		goto out;
+	}
+
+	/* DMI_CFG: auto-increment enable | ram_select */
+	writel_relaxed(BIT(8) | cmd->ram_select,
+		       vfe->base + cmd->dmi_cfg_offset);
+	writel_relaxed(0, vfe->base + cmd->dmi_cfg_offset + 0x4); /* DMI_ADDR = 0 */
+
+	for (i = 0; i < cmd->count; i++)
+		writel_relaxed(data[i],
+			       vfe->base + cmd->dmi_cfg_offset + 0xc); /* DMI_DATA_LO */
+
+	/* Disable DMI */
+	writel_relaxed(0, vfe->base + cmd->dmi_cfg_offset);
+	wmb();
+
+out:
+	kvfree(data);
+	return ret;
+}
+
+static long vfe_17x_map_buf(struct vfe_device *vfe, void __user *arg)
+{
+	struct vfe_map_buf_cmd *cmd = arg;
+	struct vfe_mapped_buf *mb;
+	struct dma_buf *dmabuf;
+	int ret;
+
+	pr_info("vfe_map_buf: fd=%d\n", cmd->fd);
+	dmabuf = dma_buf_get(cmd->fd);
+	if (IS_ERR(dmabuf)) {
+		pr_info("vfe_map_buf: dma_buf_get failed: %ld\n", PTR_ERR(dmabuf));
+		return PTR_ERR(dmabuf);
+	}
+
+	mb = kzalloc(sizeof(*mb), GFP_KERNEL);
+	if (!mb) {
+		dma_buf_put(dmabuf);
+		return -ENOMEM;
+	}
+
+	mb->dmabuf = dmabuf;
+	mb->attach = dma_buf_attach(dmabuf, vfe->camss->dev);
+	if (IS_ERR(mb->attach)) {
+		pr_info("vfe_map_buf: dma_buf_attach failed: %ld\n", PTR_ERR(mb->attach));
+		ret = PTR_ERR(mb->attach);
+		goto err_free;
+	}
+
+	mb->sgt = dma_buf_map_attachment(mb->attach, DMA_FROM_DEVICE);
+	if (IS_ERR(mb->sgt)) {
+		pr_info("vfe_map_buf: dma_buf_map_attachment failed: %ld\n", PTR_ERR(mb->sgt));
+		ret = PTR_ERR(mb->sgt);
+		goto err_detach;
+	}
+
+	mb->iova = sg_dma_address(mb->sgt->sgl);
+	mb->size = dmabuf->size;
+	pr_info("vfe_map_buf: success fd=%d iova=0x%llx size=%zu\n",
+		cmd->fd, (unsigned long long)mb->iova, mb->size);
+
+	ret = xa_insert(&vfe->mapped_bufs, (unsigned long)(mb->iova >> PAGE_SHIFT),
+			mb, GFP_KERNEL);
+	if (ret)
+		goto err_unmap;
+
+	/* V4L2 framework handles copy_to_user for _IOWR ioctls */
+	cmd->iova = mb->iova;
+	cmd->size = mb->size;
+
+	return 0;
+
+err_unmap:
+	dma_buf_unmap_attachment(mb->attach, mb->sgt, DMA_FROM_DEVICE);
+err_detach:
+	dma_buf_detach(dmabuf, mb->attach);
+err_free:
+	kfree(mb);
+	dma_buf_put(dmabuf);
+	return ret;
+}
+
+static long vfe_17x_unmap_buf(struct vfe_device *vfe, void __user *arg)
+{
+	struct vfe_unmap_buf_cmd *cmd = arg;
+	struct vfe_mapped_buf *mb;
+
+	mb = xa_erase(&vfe->mapped_bufs, (unsigned long)(cmd->iova >> PAGE_SHIFT));
+	if (!mb)
+		return -ENOENT;
+
+	dma_buf_unmap_attachment(mb->attach, mb->sgt, DMA_FROM_DEVICE);
+	dma_buf_detach(mb->dmabuf, mb->attach);
+	dma_buf_put(mb->dmabuf);
+	kfree(mb);
+
+	return 0;
+}
+
+static long vfe_17x_set_buf(struct vfe_device *vfe, struct vfe_line *line,
+			    void __user *arg)
+{
+	struct vfe_set_buf_cmd *cmd = arg;
+
+	if (cmd->wm_index >= MSM_VFE_IMAGE_MASTERS_NUM)
+		return -EINVAL;
+
+	writel_relaxed((u32)cmd->iova,
+		       vfe->base + VFE_BUS_WM_IMAGE_ADDR(cmd->wm_index));
+	writel_relaxed(cmd->stride,
+		       vfe->base + VFE_BUS_WM_STRIDE(cmd->wm_index));
+	writel_relaxed(cmd->frame_inc,
+		       vfe->base + VFE_BUS_WM_FRAME_INC(cmd->wm_index));
+	wmb();
+
+	return 0;
+}
