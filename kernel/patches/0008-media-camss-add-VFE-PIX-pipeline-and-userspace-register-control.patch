+static long vfe_17x_start(struct vfe_device *vfe, struct vfe_line *line)
+{
+	struct media_entity *entity;
+	struct media_pad *pad;
+	struct v4l2_subdev *subdev;
+	int ret;
+
+	/* Power on VFE (PM domain, clocks, reset) */
+	ret = vfe_get(vfe);
+	if (ret)
+		return ret;
+
+	/* Enable IRQs */
+	mutex_lock(&vfe->stream_lock);
+	if (!vfe->stream_count)
+		vfe_enable_irq_common(vfe);
+	vfe->stream_count++;
+	mutex_unlock(&vfe->stream_lock);
+
+	/* Reserve write masters for PIX line */
+	ret = vfe_get_output_v2(line);
+	if (ret < 0)
+		goto error_stream;
+
+	/* Configure PIX write masters */
+	{
+		struct vfe_output *output = &line->output;
+		int i;
+
+		for (i = 0; i < output->wm_num; i++)
+			vfe->res->hw_ops->vfe_wm_start(vfe, output->wm_idx[i], line);
+	}
+
+	/* Start media pipeline (validates format matching across links) */
+	ret = video_device_pipeline_alloc_start(&line->video_out.vdev);
+	if (ret < 0)
+		pr_warn("vfe_17x_start: pipeline_start returned %d, continuing anyway\n", ret);
+
+	/* Walk upstream from VFE subdev and call s_stream(1) on each entity */
+	entity = &line->subdev.entity;
+	while (1) {
+		pad = &entity->pads[0];
+		if (!(pad->flags & MEDIA_PAD_FL_SINK))
+			break;
+
+		pad = media_pad_remote_pad_first(pad);
+		if (!pad || !is_media_entity_v4l2_subdev(pad->entity))
+			break;
+
+		entity = pad->entity;
+		subdev = media_entity_to_v4l2_subdev(entity);
+
+		pr_info("vfe_17x_start: calling s_stream(1) on %s\n", subdev->name);
+		ret = v4l2_subdev_call(subdev, video, s_stream, 1);
+		pr_info("vfe_17x_start: s_stream on %s returned %d\n", subdev->name, ret);
+		if (ret < 0 && ret != -ENOIOCTLCMD) {
+			pr_err("vfe_17x_start: s_stream failed on %s: %d\n",
+			       subdev->name, ret);
+			goto error_pipeline;
+		}
+	}
+
+	vfe->was_streaming = 1;
+	pr_info("vfe_17x_start: VFE%d PIX started, wm=[%d,%d]\n",
+		vfe->id, line->output.wm_idx[0], line->output.wm_idx[1]);
+
+	return 0;
+
+error_pipeline:
+error_output:
+	vfe_put_output(line);
+error_stream:
+	mutex_lock(&vfe->stream_lock);
+	vfe->stream_count--;
+	mutex_unlock(&vfe->stream_lock);
+	vfe_put(vfe);
+	return ret;
+}
+
+static long vfe_17x_stop(struct vfe_device *vfe, struct vfe_line *line)
+{
+	struct vfe_output *output = &line->output;
+	int i;
+
+	for (i = 0; i < output->wm_num; i++)
+		vfe->res->hw_ops->vfe_wm_stop(vfe, output->wm_idx[i]);
+
+	mutex_lock(&vfe->stream_lock);
+	vfe->stream_count--;
+	mutex_unlock(&vfe->stream_lock);
+
+	vfe_put(vfe);
+	return 0;
+}
+
+static long vfe_17x_wait_sof(struct vfe_device *vfe, struct vfe_line *line)
+{
+	unsigned long ret;
+
+	reinit_completion(&line->output.sof);
+	ret = wait_for_completion_timeout(&line->output.sof, msecs_to_jiffies(200));
+	return ret ? 0 : -ETIMEDOUT;
+}
