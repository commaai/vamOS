+static long camss_video_vidioc_default(struct file *file, void *fh,
+				       bool valid_prio, unsigned int cmd,
+				       void *arg)
+{
+	struct camss_video *video = video_drvdata(file);
+	struct vfe_line *line = container_of(video, struct vfe_line, video_out);
+	struct vfe_device *vfe = to_vfe(line);
+	const struct vfe_hw_ops *ops = vfe->res->hw_ops;
+
+	switch (cmd) {
+	case VFE_WRITE_REGS:
+		return ops->write_regs ? ops->write_regs(vfe, arg) : -ENOTTY;
+	case VFE_WRITE_DMI:
+		return ops->write_dmi ? ops->write_dmi(vfe, arg) : -ENOTTY;
+	case VFE_MAP_BUF:
+		return ops->map_buf ? ops->map_buf(vfe, arg) : -ENOTTY;
+	case VFE_UNMAP_BUF:
+		return ops->unmap_buf ? ops->unmap_buf(vfe, arg) : -ENOTTY;
+	case VFE_SET_BUF:
+		return ops->set_buf ? ops->set_buf(vfe, line, arg) : -ENOTTY;
+	case VFE_REG_UPDATE:
+		return ops->reg_update_ioctl ? ops->reg_update_ioctl(vfe, line) : -ENOTTY;
+	case VFE_START:
+		return ops->start ? ops->start(vfe, line) : -ENOTTY;
+	case VFE_STOP:
+		return ops->stop ? ops->stop(vfe, line) : -ENOTTY;
+	case VFE_WAIT_SOF:
+		return ops->wait_sof ? ops->wait_sof(vfe, line) : -ENOTTY;
+	default:
+		return -ENOTTY;
+	}
+}
