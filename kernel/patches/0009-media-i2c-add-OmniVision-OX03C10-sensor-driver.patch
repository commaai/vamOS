+/* MIPI link frequency for 4-lane 12-bit @ 1200 Mbps/lane */
+#define OX03C10_LINK_FREQ		600000000ULL
+#define OX03C10_PIXEL_RATE		88000000ULL
+
+/* Chip ID: 0x300a = high byte (0x58), 0x300b = low byte (0x03) */
+#define OX03C10_REG_CHIP_ID_H		CCI_REG8(0x300a)
+#define OX03C10_REG_CHIP_ID_L		CCI_REG8(0x300b)
+#define OX03C10_CHIP_ID_H		0x58
+#define OX03C10_CHIP_ID_L		0x03
+
+/* Streaming control */
+#define OX03C10_REG_MODE_SELECT		CCI_REG8(0x0100)
+#define OX03C10_MODE_STANDBY		0x00
+#define OX03C10_MODE_STREAMING		0x01
+
+/* Software reset */
+#define OX03C10_REG_SW_RESET		CCI_REG8(0x0103)
+
+/* Exposure (HCG coarse) */
+#define OX03C10_REG_EXPOSURE_H		CCI_REG8(0x3501)
+#define OX03C10_REG_EXPOSURE_L		CCI_REG8(0x3502)
+
+/* Analog gain */
+#define OX03C10_REG_AGAIN_H		CCI_REG8(0x3508)
+#define OX03C10_REG_AGAIN_L		CCI_REG8(0x3509)
+
+/* Frame length (VTS) */
+#define OX03C10_REG_VTS_H		CCI_REG8(0x380e)
+#define OX03C10_REG_VTS_L		CCI_REG8(0x380f)
+
+#define OX03C10_NATIVE_WIDTH		1928
+#define OX03C10_NATIVE_HEIGHT		1208
+
+#define OX03C10_EXPOSURE_MIN		2
+#define OX03C10_EXPOSURE_MAX		2016
+#define OX03C10_EXPOSURE_DEFAULT	5
+
+/* Analog gain: register value 0x100 = 1x, 0xF80 = 15.5x */
+#define OX03C10_AGAIN_MIN		0x100
+#define OX03C10_AGAIN_MAX		0xF80
+#define OX03C10_AGAIN_DEFAULT		0x100
+
+#define OX03C10_VTS_DEFAULT		0x0815
+#define OX03C10_VTS_MAX			0xFFFF
+
+#define to_ox03c10(_sd) container_of(_sd, struct ox03c10, sd)
+
+struct ox03c10_reg_list {
+	u32 num_of_regs;
+	const struct cci_reg_sequence *regs;
+};
