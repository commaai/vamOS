+
+struct ox03c10 {
+	struct v4l2_subdev sd;
+	struct media_pad pad;
+	struct v4l2_ctrl_handler ctrl_handler;
+
+	struct v4l2_ctrl *link_freq;
+	struct v4l2_ctrl *pixel_rate;
+	struct v4l2_ctrl *hblank;
+	struct v4l2_ctrl *vblank;
+
+	struct device *dev;
+	struct regmap *cci;
+	struct clk *clk;
+	struct gpio_desc *reset_gpio;
+	struct regulator_bulk_data supplies[ARRAY_SIZE(ox03c10_supplies)];
+	unsigned long link_freq_bitmap;
+	const struct ox03c10_mode *cur_mode;
+};
+
+static int ox03c10_set_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct ox03c10 *sensor =
+		container_of(ctrl->handler, struct ox03c10, ctrl_handler);
+	struct i2c_client *client = v4l2_get_subdevdata(&sensor->sd);
+	int ret = 0;
+
+	if (!pm_runtime_get_if_in_use(&client->dev))
+		return 0;
+
+	switch (ctrl->id) {
+	case V4L2_CID_ANALOGUE_GAIN:
+		ret = cci_write(sensor->cci, OX03C10_REG_AGAIN_H,
+				(ctrl->val >> 8) & 0xff, NULL);
+		ret = cci_write(sensor->cci, OX03C10_REG_AGAIN_L,
+				ctrl->val & 0xff, &ret);
+		break;
+	case V4L2_CID_EXPOSURE:
+		ret = cci_write(sensor->cci, OX03C10_REG_EXPOSURE_H,
+				(ctrl->val >> 8) & 0xff, NULL);
+		ret = cci_write(sensor->cci, OX03C10_REG_EXPOSURE_L,
+				ctrl->val & 0xff, &ret);
+		break;
+	case V4L2_CID_VBLANK:
+		ret = cci_write(sensor->cci, OX03C10_REG_VTS_H,
+				((sensor->cur_mode->height + ctrl->val) >> 8) & 0xff,
+				NULL);
+		ret = cci_write(sensor->cci, OX03C10_REG_VTS_L,
+				(sensor->cur_mode->height + ctrl->val) & 0xff,
+				&ret);
+		break;
+	default:
+		ret = -EINVAL;
+		break;
+	}
+
+	pm_runtime_put(&client->dev);
+	return ret;
+}
+
+static const struct v4l2_ctrl_ops ox03c10_ctrl_ops = {
+	.s_ctrl = ox03c10_set_ctrl,
+};
+
+static int ox03c10_init_controls(struct ox03c10 *sensor)
+{
+	struct i2c_client *client = v4l2_get_subdevdata(&sensor->sd);
+	struct v4l2_fwnode_device_properties props;
+	struct v4l2_ctrl_handler *ctrl_hdlr;
+	s64 vblank;
+	int ret;
+
+	ctrl_hdlr = &sensor->ctrl_handler;
+	ret = v4l2_ctrl_handler_init(ctrl_hdlr, 8);
+	if (ret)
+		return ret;
+
+	sensor->link_freq = v4l2_ctrl_new_int_menu(
+		ctrl_hdlr, &ox03c10_ctrl_ops, V4L2_CID_LINK_FREQ,
+		ARRAY_SIZE(ox03c10_link_freq_menu) - 1, 0,
+		ox03c10_link_freq_menu);
+	if (sensor->link_freq)
+		sensor->link_freq->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	sensor->pixel_rate = v4l2_ctrl_new_std(
+		ctrl_hdlr, &ox03c10_ctrl_ops, V4L2_CID_PIXEL_RATE,
+		OX03C10_PIXEL_RATE, OX03C10_PIXEL_RATE, 1,
+		OX03C10_PIXEL_RATE);
+	if (sensor->pixel_rate)
+		sensor->pixel_rate->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	vblank = OX03C10_VTS_MAX - sensor->cur_mode->height;
+	sensor->vblank = v4l2_ctrl_new_std(ctrl_hdlr, &ox03c10_ctrl_ops,
+					   V4L2_CID_VBLANK, 0, vblank, 1,
+					   sensor->cur_mode->vblank);
+
+	sensor->hblank = v4l2_ctrl_new_std(
+		ctrl_hdlr, &ox03c10_ctrl_ops, V4L2_CID_HBLANK, 0, 0, 1, 0);
+	if (sensor->hblank)
+		sensor->hblank->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	v4l2_ctrl_new_std(ctrl_hdlr, &ox03c10_ctrl_ops,
+			  V4L2_CID_ANALOGUE_GAIN, OX03C10_AGAIN_MIN,
+			  OX03C10_AGAIN_MAX, 1, OX03C10_AGAIN_DEFAULT);
+
+	v4l2_ctrl_new_std(ctrl_hdlr, &ox03c10_ctrl_ops, V4L2_CID_EXPOSURE,
+			  OX03C10_EXPOSURE_MIN, OX03C10_EXPOSURE_MAX, 1,
+			  OX03C10_EXPOSURE_DEFAULT);
+
+	if (ctrl_hdlr->error)
+		return ctrl_hdlr->error;
+
+	ret = v4l2_fwnode_device_parse(&client->dev, &props);
+	if (ret)
+		return ret;
+
+	ret = v4l2_ctrl_new_fwnode_properties(ctrl_hdlr, &ox03c10_ctrl_ops,
+					      &props);
+	if (ret)
+		return ret;
+
+	sensor->sd.ctrl_handler = ctrl_hdlr;
+	return 0;
+}
+
+static void ox03c10_update_pad_format(const struct ox03c10_mode *mode,
+				      struct v4l2_mbus_framefmt *fmt)
+{
+	fmt->width = mode->width;
+	fmt->height = mode->height;
+	fmt->code = mode->code;
+	fmt->field = V4L2_FIELD_NONE;
+}
+
+static int ox03c10_start_streaming(struct ox03c10 *sensor)
+{
+	struct i2c_client *client = v4l2_get_subdevdata(&sensor->sd);
+	const struct ox03c10_reg_list *reg_list;
+	int ret;
+
+	reg_list = &sensor->cur_mode->reg_list;
+	ret = cci_multi_reg_write(sensor->cci, reg_list->regs,
+				  reg_list->num_of_regs, NULL);
+	if (ret) {
+		dev_err(&client->dev, "failed to write init registers\n");
+		return ret;
+	}
+
+	/* Allow registers to settle after init */
+	fsleep(10000);
+
+	ret = __v4l2_ctrl_handler_setup(sensor->sd.ctrl_handler);
+	if (ret)
+		return ret;
+
+	ret = cci_write(sensor->cci, OX03C10_REG_MODE_SELECT,
+			OX03C10_MODE_STREAMING, NULL);
+	if (ret) {
+		dev_err(&client->dev, "failed to start streaming\n");
+		return ret;
+	}
+
+	return 0;
+}
+
+static int ox03c10_stop_streaming(struct ox03c10 *sensor)
+{
+	return cci_write(sensor->cci, OX03C10_REG_MODE_SELECT,
+			 OX03C10_MODE_STANDBY, NULL);
+}
+
+static int ox03c10_set_stream(struct v4l2_subdev *sd, int enable)
+{
+	struct ox03c10 *sensor = to_ox03c10(sd);
+	struct i2c_client *client = v4l2_get_subdevdata(sd);
+	int ret = 0;
+
+	if (enable) {
+		ret = pm_runtime_resume_and_get(&client->dev);
+		if (ret < 0)
+			return ret;
+
+		ret = ox03c10_start_streaming(sensor);
+		if (ret)
+			goto error_rpm_put;
+	} else {
+		ox03c10_stop_streaming(sensor);
+		pm_runtime_put(&client->dev);
+	}
+
+	return ret;
+
+error_rpm_put:
+	pm_runtime_put(&client->dev);
+	return ret;
+}
+
+static int ox03c10_get_fmt(struct v4l2_subdev *sd,
+			   struct v4l2_subdev_state *sd_state,
+			   struct v4l2_subdev_format *fmt)
+{
+	struct ox03c10 *sensor = to_ox03c10(sd);
+
+	if (fmt->which == V4L2_SUBDEV_FORMAT_TRY) {
+		struct v4l2_mbus_framefmt *framefmt;
+
+		framefmt = v4l2_subdev_state_get_format(sd_state, fmt->pad);
+		fmt->format = *framefmt;
+	} else {
+		ox03c10_update_pad_format(sensor->cur_mode, &fmt->format);
+	}
+
+	return 0;
+}
+
+static int ox03c10_set_fmt(struct v4l2_subdev *sd,
+			   struct v4l2_subdev_state *sd_state,
+			   struct v4l2_subdev_format *fmt)
+{
+	struct ox03c10 *sensor = to_ox03c10(sd);
+	const struct ox03c10_mode *mode;
+
+	mode = v4l2_find_nearest_size(ox03c10_modes,
+				      ARRAY_SIZE(ox03c10_modes), width,
+				      height, fmt->format.width,
+				      fmt->format.height);
+
+	ox03c10_update_pad_format(mode, &fmt->format);
+
+	if (fmt->which == V4L2_SUBDEV_FORMAT_TRY) {
+		*v4l2_subdev_state_get_format(sd_state, fmt->pad) =
+			fmt->format;
+	} else {
+		sensor->cur_mode = mode;
+		__v4l2_ctrl_s_ctrl(sensor->link_freq,
+				   mode->link_freq_index);
+		__v4l2_ctrl_modify_range(sensor->vblank, 0,
+					 OX03C10_VTS_MAX - mode->height, 1,
+					 sensor->cur_mode->vblank);
+		__v4l2_ctrl_s_ctrl(sensor->vblank,
+				   sensor->cur_mode->vblank);
+	}
+
+	return 0;
+}
+
+static int ox03c10_enum_mbus_code(struct v4l2_subdev *sd,
+				  struct v4l2_subdev_state *sd_state,
+				  struct v4l2_subdev_mbus_code_enum *code)
+{
+	if (code->index > 0)
+		return -EINVAL;
+
+	code->code = MEDIA_BUS_FMT_SGRBG12_1X12;
+	return 0;
+}
+
+static int ox03c10_enum_frame_size(struct v4l2_subdev *sd,
+				   struct v4l2_subdev_state *sd_state,
+				   struct v4l2_subdev_frame_size_enum *fse)
+{
+	if (fse->index >= ARRAY_SIZE(ox03c10_modes))
+		return -EINVAL;
+
+	if (fse->code != MEDIA_BUS_FMT_SGRBG12_1X12)
+		return -EINVAL;
+
+	fse->min_width = ox03c10_modes[fse->index].width;
+	fse->max_width = fse->min_width;
+	fse->min_height = ox03c10_modes[fse->index].height;
+	fse->max_height = fse->min_height;
+
+	return 0;
+}
+
+static int ox03c10_get_selection(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *state,
+				 struct v4l2_subdev_selection *sel)
+{
+	switch (sel->target) {
+	case V4L2_SEL_TGT_CROP:
+	case V4L2_SEL_TGT_CROP_DEFAULT:
+		sel->r = *v4l2_subdev_state_get_crop(state, 0);
+		break;
+	case V4L2_SEL_TGT_CROP_BOUNDS:
+	case V4L2_SEL_TGT_NATIVE_SIZE:
+		sel->r.top = 0;
+		sel->r.left = 0;
+		sel->r.width = OX03C10_NATIVE_WIDTH;
+		sel->r.height = OX03C10_NATIVE_HEIGHT;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int ox03c10_init_state(struct v4l2_subdev *sd,
+			      struct v4l2_subdev_state *sd_state)
+{
+	const struct ox03c10_mode *def_mode = &ox03c10_modes[0];
+	struct v4l2_subdev_format fmt = {
+		.which = V4L2_SUBDEV_FORMAT_TRY,
+		.format = {
+			.code = MEDIA_BUS_FMT_SGRBG12_1X12,
+			.width = def_mode->width,
+			.height = def_mode->height,
+		},
+	};
+
+	ox03c10_set_fmt(sd, sd_state, &fmt);
+	return 0;
+}
+
+static const struct v4l2_subdev_video_ops ox03c10_video_ops = {
+	.s_stream = ox03c10_set_stream,
+};
+
+static const struct v4l2_subdev_pad_ops ox03c10_pad_ops = {
+	.enum_mbus_code = ox03c10_enum_mbus_code,
+	.enum_frame_size = ox03c10_enum_frame_size,
+	.get_fmt = ox03c10_get_fmt,
+	.set_fmt = ox03c10_set_fmt,
+	.get_selection = ox03c10_get_selection,
+};
+
+static const struct v4l2_subdev_core_ops ox03c10_core_ops = {
+	.subscribe_event = v4l2_ctrl_subdev_subscribe_event,
+	.unsubscribe_event = v4l2_event_subdev_unsubscribe,
+};
+
+static const struct v4l2_subdev_ops ox03c10_subdev_ops = {
+	.core = &ox03c10_core_ops,
+	.video = &ox03c10_video_ops,
+	.pad = &ox03c10_pad_ops,
+};
+
+static const struct media_entity_operations ox03c10_subdev_entity_ops = {
+	.link_validate = v4l2_subdev_link_validate,
+};
+
+static const struct v4l2_subdev_internal_ops ox03c10_internal_ops = {
+	.init_state = ox03c10_init_state,
+};
+
+static int ox03c10_parse_hw_config(struct ox03c10 *sensor)
+{
+	struct fwnode_handle *endpoint;
+	struct v4l2_fwnode_endpoint ep_cfg = {
+		.bus_type = V4L2_MBUS_CSI2_DPHY,
+	};
+	int i, ret;
+
+	sensor->clk = devm_clk_get(sensor->dev, NULL);
+	if (IS_ERR(sensor->clk))
+		return dev_err_probe(sensor->dev, PTR_ERR(sensor->clk),
+				     "Failed to get clock\n");
+
+	sensor->reset_gpio =
+		devm_gpiod_get_optional(sensor->dev, "reset", GPIOD_OUT_HIGH);
+	if (IS_ERR(sensor->reset_gpio))
+		return dev_err_probe(sensor->dev,
+				     PTR_ERR(sensor->reset_gpio),
+				     "Failed to get reset gpio\n");
+
+	for (i = 0; i < ARRAY_SIZE(ox03c10_supplies); i++)
+		sensor->supplies[i].supply = ox03c10_supplies[i];
+
+	ret = devm_regulator_bulk_get(sensor->dev,
+				      ARRAY_SIZE(ox03c10_supplies),
+				      sensor->supplies);
+	if (ret)
+		return dev_err_probe(sensor->dev, ret,
+				     "Cannot get supplies\n");
+
+	endpoint =
+		fwnode_graph_get_next_endpoint(dev_fwnode(sensor->dev), NULL);
+	if (!endpoint) {
+		dev_err(sensor->dev, "endpoint node not found\n");
+		return -EPROBE_DEFER;
+	}
+
+	ret = v4l2_fwnode_endpoint_alloc_parse(endpoint, &ep_cfg);
+	if (ret) {
+		dev_err(sensor->dev, "parsing endpoint node failed\n");
+		goto error_out;
+	}
+
+	ret = v4l2_link_freq_to_bitmap(sensor->dev, ep_cfg.link_frequencies,
+				       ep_cfg.nr_of_link_frequencies,
+				       ox03c10_link_freq_menu,
+				       ARRAY_SIZE(ox03c10_link_freq_menu),
+				       &sensor->link_freq_bitmap);
+
+error_out:
+	v4l2_fwnode_endpoint_free(&ep_cfg);
+	fwnode_handle_put(endpoint);
+	return ret;
+}
+
+static int ox03c10_identify_module(struct ox03c10 *sensor)
+{
+	struct i2c_client *client = v4l2_get_subdevdata(&sensor->sd);
+	u64 val_h, val_l;
+	int ret;
+
+	ret = cci_read(sensor->cci, OX03C10_REG_CHIP_ID_H, &val_h, NULL);
+	if (ret)
+		return ret;
+
+	ret = cci_read(sensor->cci, OX03C10_REG_CHIP_ID_L, &val_l, NULL);
+	if (ret)
+		return ret;
+
+	if (val_h != OX03C10_CHIP_ID_H || val_l != OX03C10_CHIP_ID_L) {
+		dev_err(&client->dev,
+			"chip id mismatch: expected %02x%02x, got %02llx%02llx\n",
+			OX03C10_CHIP_ID_H, OX03C10_CHIP_ID_L, val_h, val_l);
+		return -ENXIO;
+	}
+
+	dev_info(&client->dev, "OX03C10 chip ID verified: 0x%02llx%02llx\n",
+		 val_h, val_l);
+	return 0;
+}
+
+static int ox03c10_power_on(struct device *dev)
+{
+	struct i2c_client *client = to_i2c_client(dev);
+	struct v4l2_subdev *sd = i2c_get_clientdata(client);
+	struct ox03c10 *sensor = to_ox03c10(sd);
+	int ret;
+
+	/* Assert reset */
+	if (sensor->reset_gpio)
+		gpiod_set_value_cansleep(sensor->reset_gpio, 1);
+
+	ret = regulator_bulk_enable(ARRAY_SIZE(ox03c10_supplies),
+				    sensor->supplies);
+	if (ret) {
+		dev_err(sensor->dev, "Failed to enable regulators\n");
+		return ret;
+	}
+
+	ret = clk_prepare_enable(sensor->clk);
+	if (ret) {
+		dev_err(sensor->dev, "Failed to enable clock\n");
+		goto error_regulators;
+	}
+
+	/* De-assert reset */
+	if (sensor->reset_gpio)
+		gpiod_set_value_cansleep(sensor->reset_gpio, 0);
+
+	/* Wait for sensor to come out of reset. OV sensors typically
+	 * need ~20ms after reset de-assertion. Use 30ms for margin. */
+	fsleep(30000);
+
+	return 0;
+
+error_regulators:
+	if (sensor->reset_gpio)
+		gpiod_set_value_cansleep(sensor->reset_gpio, 1);
+	regulator_bulk_disable(ARRAY_SIZE(ox03c10_supplies),
+			       sensor->supplies);
+	return ret;
+}
+
+static int ox03c10_power_off(struct device *dev)
+{
+	struct i2c_client *client = to_i2c_client(dev);
+	struct v4l2_subdev *sd = i2c_get_clientdata(client);
+	struct ox03c10 *sensor = to_ox03c10(sd);
+
+	if (sensor->reset_gpio)
+		gpiod_set_value_cansleep(sensor->reset_gpio, 1);
+	clk_disable_unprepare(sensor->clk);
+	regulator_bulk_disable(ARRAY_SIZE(ox03c10_supplies),
+			       sensor->supplies);
+
+	return 0;
+}
+
+static int ox03c10_probe(struct i2c_client *client)
+{
+	struct ox03c10 *sensor;
+	int ret;
+
+	sensor = devm_kzalloc(&client->dev, sizeof(*sensor), GFP_KERNEL);
+	if (!sensor)
+		return -ENOMEM;
+
+	sensor->dev = &client->dev;
+
+	/* OX03C10 uses 16-bit register addresses, 8-bit data */
+	sensor->cci = devm_cci_regmap_init_i2c(client, 16);
+	if (IS_ERR(sensor->cci))
+		return dev_err_probe(sensor->dev, PTR_ERR(sensor->cci),
+				     "Failed to initialize CCI\n");
+
+	v4l2_i2c_subdev_init(&sensor->sd, client, &ox03c10_subdev_ops);
+
+	ret = ox03c10_parse_hw_config(sensor);
+	if (ret)
+		return ret;
+
+	ret = ox03c10_power_on(sensor->dev);
+	if (ret)
+		return dev_err_probe(sensor->dev, ret,
+				     "Could not power on the device\n");
+
+	ret = ox03c10_identify_module(sensor);
+	if (ret) {
+		dev_err(&client->dev, "failed to find sensor: %d\n", ret);
+		goto error_power_off;
+	}
+
+	sensor->cur_mode = &ox03c10_modes[0];
+	ret = ox03c10_init_controls(sensor);
+	if (ret) {
+		dev_err(&client->dev, "failed to init controls: %d\n", ret);
+		goto error_power_off;
+	}
+
+	sensor->sd.internal_ops = &ox03c10_internal_ops;
+	sensor->sd.flags |=
+		V4L2_SUBDEV_FL_HAS_DEVNODE | V4L2_SUBDEV_FL_HAS_EVENTS;
+	sensor->sd.entity.ops = &ox03c10_subdev_entity_ops;
+	sensor->sd.entity.function = MEDIA_ENT_F_CAM_SENSOR;
+
+	sensor->pad.flags = MEDIA_PAD_FL_SOURCE;
+	ret = media_entity_pads_init(&sensor->sd.entity, 1, &sensor->pad);
+	if (ret) {
+		dev_err(&client->dev, "failed to init entity pads: %d\n", ret);
+		goto error_ctrl_handler;
+	}
+
+	sensor->sd.state_lock = sensor->ctrl_handler.lock;
+	ret = v4l2_subdev_init_finalize(&sensor->sd);
+	if (ret < 0) {
+		dev_err(sensor->dev, "v4l2 subdev init error: %d\n", ret);
+		goto error_media_entity;
+	}
+
+	ret = v4l2_async_register_subdev_sensor(&sensor->sd);
+	if (ret < 0) {
+		dev_err(&client->dev,
+			"failed to register V4L2 subdev: %d\n", ret);
+		goto error_subdev_cleanup;
+	}
+
+	pm_runtime_set_active(sensor->dev);
+	pm_runtime_enable(sensor->dev);
+	pm_runtime_idle(sensor->dev);
+
+	return 0;
+
+error_subdev_cleanup:
+	v4l2_subdev_cleanup(&sensor->sd);
+
+error_media_entity:
+	media_entity_cleanup(&sensor->sd.entity);
+
+error_ctrl_handler:
+	v4l2_ctrl_handler_free(sensor->sd.ctrl_handler);
+
+error_power_off:
+	ox03c10_power_off(sensor->dev);
+	return ret;
+}
+
+static void ox03c10_remove(struct i2c_client *client)
+{
+	struct v4l2_subdev *sd = i2c_get_clientdata(client);
+	struct ox03c10 *sensor = to_ox03c10(sd);
+
+	v4l2_async_unregister_subdev(sd);
+	v4l2_subdev_cleanup(sd);
+	media_entity_cleanup(&sd->entity);
+	v4l2_ctrl_handler_free(&sd->ctrl_handler);
+
+	pm_runtime_disable(&client->dev);
+	if (!pm_runtime_status_suspended(&client->dev))
+		ox03c10_power_off(&client->dev);
+	pm_runtime_set_suspended(&client->dev);
+}
+
+static const struct of_device_id ox03c10_of_match[] = {
+	{ .compatible = "ovti,ox03c10" },
+	{}
+};
+MODULE_DEVICE_TABLE(of, ox03c10_of_match);
+
+static const struct dev_pm_ops ox03c10_pm_ops = {
+	SET_RUNTIME_PM_OPS(ox03c10_power_off, ox03c10_power_on, NULL)
+};
+
+static struct i2c_driver ox03c10_i2c_driver = {
+	.driver = {
+		.name = "ox03c10",
+		.of_match_table = of_match_ptr(ox03c10_of_match),
+		.pm = &ox03c10_pm_ops,
+	},
+	.probe = ox03c10_probe,
+	.remove = ox03c10_remove,
+};
+
+module_i2c_driver(ox03c10_i2c_driver);
+
+MODULE_DESCRIPTION("OmniVision OX03C10 sensor driver");
+MODULE_AUTHOR("Andi Radu <andi@comma.ai>");
+MODULE_LICENSE("GPL");
