+/*
+ * vfe_dmi_upload_lut - Upload a LUT via DMI (Data Memory Interface)
+ * @vfe: VFE device
+ * @ram_sel: DMI RAM select value for target LUT bank
+ * @data: array of 32-bit LUT entries
+ * @count: number of entries
+ */
+static void vfe_dmi_upload_lut(struct vfe_device *vfe, u8 ram_sel,
+			       const u32 *data, int count)
+{
+	int i;
+
+	writel_relaxed(DMI_AUTO_INC_EN | ram_sel, vfe->base + VFE_DMI_CFG);
+	writel_relaxed(0, vfe->base + VFE_DMI_ADDR);
+
+	for (i = 0; i < count; i++)
+		writel_relaxed(data[i], vfe->base + VFE_DMI_DATA_LO);
+
+	writel_relaxed(0, vfe->base + VFE_DMI_CFG);
+}
