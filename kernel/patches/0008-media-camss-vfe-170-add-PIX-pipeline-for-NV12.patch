+/*
+ * OX03C10 gamma LUT from openpilot: 64 packed entries.
+ * Each entry: bits [9:0] = base (10-bit), bits [31:10] = delta to next.
+ * Custom tonemapping: -0.507089*exp(-12.54*x) + 0.9655*sqrt(x) - 0.4726*x + 0.507089
+ */
+static const u32 ox03c10_gamma_lut[64] = {
+	0x00034000, 0x0001e0d0, 0x00017948, 0x000135a6,
+	0x0000fdf3, 0x0000da32, 0x0000b668, 0x00009a95,
+	0x000086bb, 0x000076dc, 0x000062f9, 0x00005711,
+	0x00004f26, 0x00004739, 0x00003b4a, 0x00003758,
+	0x00003365, 0x00002b71, 0x00002b7b, 0x00002785,
+	0x00001f8e, 0x00002395, 0x00001b9d, 0x00001fa3,
+	0x000017aa, 0x00001baf, 0x000017b5, 0x000013ba,
+	0x000017be, 0x000013c3, 0x000013c7, 0x00000fcb,
+	0x000013ce, 0x00000fd2, 0x00000fd5, 0x00000fd8,
+	0x00000fdb, 0x00000bde, 0x00000fe0, 0x00000be3,
+	0x00000be5, 0x00000be7, 0x00000be9, 0x00000beb,
+	0x00000bed, 0x00000bef, 0x000007f1, 0x000007f2,
+	0x00000bf3, 0x000007f5, 0x000007f6, 0x000007f7,
+	0x000007f8, 0x000007f9, 0x000007fa, 0x000007fb,
+	0x000003fc, 0x000007fc, 0x000003fd, 0x000007fd,
+	0x000003fe, 0x000007fe, 0x000003ff, 0x000003ff,
+};
+
+/*
+ * OX03C10 linearization LUT: 36 entries (9 segments x 4 Bayer channels).
+ * Each entry: bits [13:0] = base (14-bit), bits [31:14] = slope (18-bit Q7.11).
+ * HDR linearization: low gain in shadows, ramps to 8x in highlights.
+ */
+static const u32 ox03c10_linear_lut[36] = {
+	0x00200000, 0x00200000, 0x00200000, 0x00200000,
+	0x00404080, 0x00404080, 0x00404080, 0x00404080,
+	0x00804100, 0x00804100, 0x00804100, 0x00804100,
+	0x02014402, 0x02014402, 0x02014402, 0x02014402,
+	0x0402c804, 0x0402c804, 0x0402c804, 0x0402c804,
+	0x0805d00a, 0x0805d00a, 0x0805d00a, 0x0805d00a,
+	0x100ba015, 0x100ba015, 0x100ba015, 0x100ba015,
+	0x00003fff, 0x00003fff, 0x00003fff, 0x00003fff,
+	0x00003fff, 0x00003fff, 0x00003fff, 0x00003fff,
+};
+
+/* OX03C10 linearization kneepoints: 8 kneepoints packed 2 per register */
+static const u32 ox03c10_linear_pts[4] = {
+	0x07ff0bff, 0x17ff1bff, 0x1fff23ff, 0x27ff3fff,
+};
