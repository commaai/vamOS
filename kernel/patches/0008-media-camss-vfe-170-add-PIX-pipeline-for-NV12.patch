+/*
+ * vfe_pix_set_crop_wm - Configure BUS write master mapping for PIX
+ *
+ * Programs VFE_BUS_COMP_GROUP to route Y to wm_y and UV to wm_uv.
+ */
+static void vfe_pix_set_crop_wm(struct vfe_device *vfe, u8 wm_y, u8 wm_uv)
+{
+	/*
+	 * 0x2018: PIX output enable - tells BUS which WMs receive ISP output.
+	 * Without this, ISP processes data but has nowhere to write it.
+	 * Downstream value: 0x18 = BIT(3)|BIT(4) for WM3+WM4.
+	 */
+	writel_relaxed(BIT(wm_y) | BIT(wm_uv), vfe->base + 0x2018);
+
+	/*
+	 * Per-WM output port mapping at offset 0xa0 within each WM block.
+	 * Downstream sets both WM3 and WM4 to 0x16 (22).
+	 */
+	writel_relaxed(0x16, vfe->base + VFE_BUS_WM_STATUS0(wm_y) + 0xa0);
+	writel_relaxed(0x16, vfe->base + VFE_BUS_WM_STATUS0(wm_uv) + 0xa0);
+
+	/*
+	 * COMP_GROUP0 groups WM3+WM4 for composite done IRQ.
+	 * ISR checks COMP0_BUF_DONE (BIT(5) in bus_status[0]).
+	 */
+	writel_relaxed(BIT(wm_y) | BIT(wm_uv), vfe->base + VFE_BUS_COMP_GROUP(0));
+}
