+/* ------------------------------------------------------------------ */
+/* PIX (ISP pixel processing) pipeline for debayered NV12 output      */
+/* Register values from openpilot ife.h (programs same HW via CDM)    */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Program the IFE Titan 170 ISP pipeline.
+ * Pipeline: CAMIF -> Demux -> BlackLevel -> WhiteBalance -> Debayer
+ *           -> ColorCorrection -> YUV -> Scale -> Crop -> WM
+ * Gamma/linearization/vignetting skipped (need DMI LUT uploads).
+ */
+static void vfe_pix_configure_isp(struct vfe_device *vfe,
+				  u32 in_w, u32 in_h,
+				  u32 out_w, u32 out_h)
+{
+	dev_info(vfe->camss->dev, "PIX ISP configure: in=%ux%u out=%ux%u\n",
+		 in_w, in_h, out_w, out_h);
+
+	/* Clear status registers */
+	writel_relaxed(~0u, vfe->base + 0x2c);
+	writel_relaxed(~0u, vfe->base + 0x30);
+	writel_relaxed(~0u, vfe->base + 0x34);
+	writel_relaxed(~0u, vfe->base + 0x38);
+	writel_relaxed(~0u, vfe->base + 0x3c);
+
+	/* VFE core config: pixel_pattern=0 (RGGB), composite_reg_update=1 */
+	writel_relaxed(CFG_PIXEL_PATTERN_YCBYCR | CFG_COMPOSITE_REG_UPDATE_EN,
+		       vfe->base + VFE_CORE_CFG);
+
+	/* CAMIF: clear status, configure for external input (from CSID PIX)
+	 * 0x478 CMD: bit 2 = clear status
+	 * 0x47c CFG: input_mux_sel[6:5]=0 (external), pixel_pattern[2:0]=0
+	 *            raw_crop_en[22]=1
+	 */
+	writel_relaxed(0x00000004, vfe->base + 0x478);
+	writel_relaxed(0x00400000, vfe->base + 0x47c);
+
+	/* Epoch config (half frame) */
+	writel_relaxed(((in_h / 2) << 16) | 0x0014, vfe->base + 0x4a0);
+	writel_relaxed(0x00000000, vfe->base + 0x488);
+	writel_relaxed(0x00000000, vfe->base + 0x48c);
+	writel_relaxed(0x00000f0f, vfe->base + 0x490);
+	writel_relaxed(0x00000001, vfe->base + 0x49c);
+
+	/* Demux: enable, Bayer RGGB routing */
+	writel_relaxed(0x00000001, vfe->base + 0x560);
+	writel_relaxed(0x04440444, vfe->base + 0x564);
+	writel_relaxed(0x04450445, vfe->base + 0x568);
+	writel_relaxed(0x04440444, vfe->base + 0x56c);
+	writel_relaxed(0x04450445, vfe->base + 0x570);
+	writel_relaxed(0x000000ca, vfe->base + 0x574);
+	writel_relaxed(0x0000009c, vfe->base + 0x578);
+
+	/* White balance: identity gains (R=G=B=1.0) */
+	writel_relaxed(0x00800080, vfe->base + 0x6fc);
+	writel_relaxed(0x00000080, vfe->base + 0x700);
+	writel_relaxed(0x00000000, vfe->base + 0x704);
+	writel_relaxed(0x00000000, vfe->base + 0x708);
+
+	/* Module enables: debayer + white_balance + zoom, no vignetting */
+	writel_relaxed(0x00000c06, vfe->base + 0x40);
+	writel_relaxed(0x00000000, vfe->base + 0x44);
+	writel_relaxed(0x0000000a, vfe->base + 0x48);
+	writel_relaxed(0x00000019, vfe->base + 0x4c);
+
+	/* Color transform output config */
+	writel_relaxed(0x00000000, vfe->base + 0xf00);
+
+	/* Cropping module enable */
+	writel_relaxed(0x00000e00, vfe->base + 0xe0c);
+	writel_relaxed(0x00000e00, vfe->base + 0xe2c);
+
+	/* Black level (12-bit sensor, bl=64) */
+	writel_relaxed(0x04001000, vfe->base + 0x6b0);
+	writel_relaxed(0x00000000, vfe->base + 0x6b4);
+	writel_relaxed(0x00000000, vfe->base + 0x6b8);
+
+	/* Linearization: disabled */
+	writel_relaxed(0x00000000, vfe->base + 0x4dc);
+
+	/* DMI config: idle */
+	writel_relaxed(0x00000000, vfe->base + 0xce4);
+	writel_relaxed(0x00000000, vfe->base + 0xce8);
+
+	/* Debayer */
+	writel_relaxed(0x00000100, vfe->base + 0x6f8);
+	writel_relaxed(0x00008000, vfe->base + 0x71c);
+	writel_relaxed(0x08000066, vfe->base + 0x720);
+
+	/* Color correction: identity (Q7: 0x80=1.0) */
+	writel_relaxed(0x00000080, vfe->base + 0x760);
+	writel_relaxed(0x00000000, vfe->base + 0x764);
+	writel_relaxed(0x00000000, vfe->base + 0x768);
+	writel_relaxed(0x00000000, vfe->base + 0x76c);
+	writel_relaxed(0x00000080, vfe->base + 0x770);
+	writel_relaxed(0x00000000, vfe->base + 0x774);
+	writel_relaxed(0x00000000, vfe->base + 0x778);
+	writel_relaxed(0x00000000, vfe->base + 0x77c);
+	writel_relaxed(0x00000080, vfe->base + 0x780);
+
+	/* Gamma: disabled */
+	writel_relaxed(0x00000000, vfe->base + 0x798);
+
+	/* Y scaling: 1:1 (factor 0x30036666) */
+	writel_relaxed(0x00000003, vfe->base + 0xa3c);
+	writel_relaxed(((out_w - 1) << 16) | (in_w - 1), vfe->base + 0xa40);
+	writel_relaxed(0x30036666, vfe->base + 0xa44);
+	writel_relaxed(0x00000000, vfe->base + 0xa48);
+	writel_relaxed(0x00000000, vfe->base + 0xa4c);
+	writel_relaxed(in_w - 1, vfe->base + 0xa50);
+	writel_relaxed(((out_h - 1) << 16) | (in_h - 1), vfe->base + 0xa54);
+	writel_relaxed(0x30036666, vfe->base + 0xa58);
+	writel_relaxed(0x00000000, vfe->base + 0xa5c);
+	writel_relaxed(0x00000000, vfe->base + 0xa60);
+	writel_relaxed(in_h - 1, vfe->base + 0xa64);
+
+	/* CbCr scaling: 2:1 for NV12 4:2:0 (factor 0x3006cccc) */
+	writel_relaxed(0x00000003, vfe->base + 0xa68);
+	writel_relaxed(((out_w / 2 - 1) << 16) | (in_w - 1),
+		       vfe->base + 0xa6c);
+	writel_relaxed(0x3006cccc, vfe->base + 0xa70);
+	writel_relaxed(0x00000000, vfe->base + 0xa74);
+	writel_relaxed(0x00000000, vfe->base + 0xa78);
+	writel_relaxed(in_w - 1, vfe->base + 0xa7c);
+	writel_relaxed(((out_h / 2 - 1) << 16) | (in_h - 1),
+		       vfe->base + 0xa80);
+	writel_relaxed(0x3006cccc, vfe->base + 0xa84);
+	writel_relaxed(0x00000000, vfe->base + 0xa88);
+	writel_relaxed(0x00000000, vfe->base + 0xa8c);
+	writel_relaxed(in_h - 1, vfe->base + 0xa90);
+
+	/* Crop: Y (full resolution) */
+	writel_relaxed(out_h - 1, vfe->base + 0xe10);
+	writel_relaxed(out_w - 1, vfe->base + 0xe14);
+	writel_relaxed(0x0ff00000, vfe->base + 0xe18);
+
+	/* Crop: CbCr (half height for NV12) */
+	writel_relaxed(out_h / 2 - 1, vfe->base + 0xe30);
+	writel_relaxed(out_w - 1, vfe->base + 0xe34);
+	writel_relaxed(0x0ff00000, vfe->base + 0xe38);
+
+	/* YUV conversion: BT.601 (from openpilot ife.h) */
+	writel_relaxed(0x00680208, vfe->base + 0xf30);
+	writel_relaxed(0x00000108, vfe->base + 0xf34);
+	writel_relaxed(0x00400000, vfe->base + 0xf38);
+	writel_relaxed(0x03ff0000, vfe->base + 0xf3c);
+	writel_relaxed(0x01c01ed8, vfe->base + 0xf40);
+	writel_relaxed(0x00001f68, vfe->base + 0xf44);
+	writel_relaxed(0x02000000, vfe->base + 0xf48);
+	writel_relaxed(0x03ff0000, vfe->base + 0xf4c);
+	writel_relaxed(0x1fb81e88, vfe->base + 0xf50);
+	writel_relaxed(0x000001c0, vfe->base + 0xf54);
+	writel_relaxed(0x02000000, vfe->base + 0xf58);
+	writel_relaxed(0x03ff0000, vfe->base + 0xf5c);
+
+	wmb();
+}
+
+/* Route crop Y/CbCr output to specific WM client indices */
+static void vfe_pix_set_crop_wm(struct vfe_device *vfe, u8 wm_y, u8 wm_uv)
+{
+	writel_relaxed(wm_y, vfe->base + 0xe1c);
+	writel_relaxed(wm_uv, vfe->base + 0xe3c);
+	wmb();
+}
+
+/* Start a WM in PIX mode (QCOM_PLAIN, line-based) for NV12 output */
+static void vfe_wm_start_pix(struct vfe_device *vfe, u8 wm,
+			     struct vfe_line *line, int plane)
+{
+	struct v4l2_pix_format_mplane *pix =
+		&line->video_out.active_fmt.fmt.pix_mp;
+	u32 stride = pix->plane_fmt[0].bytesperline;
+	u32 height = (plane == 1) ? pix->height / 2 : pix->height;
+	u32 val;
+
+	writel_relaxed(0, vfe->base + VFE_BUS_WM_ADDR_SYNC_FRAME_HEADER);
+	writel_relaxed(WM_CGC_OVERRIDE_ALL, vfe->base + VFE_BUS_WM_CGC_OVERRIDE);
+	writel_relaxed(0x0, vfe->base + VFE_BUS_WM_TEST_BUS_CTRL);
+	writel_relaxed(WM_ADDR_NO_SYNC_DEFAULT_VAL,
+		       vfe->base + VFE_BUS_WM_ADDR_SYNC_NO_SYNC);
+
+	writel_relaxed(0xf, vfe->base + VFE_BUS_WM_BURST_LIMIT(wm));
+	writel_relaxed(stride, vfe->base + VFE_BUS_WM_BUFFER_WIDTH_CFG(wm));
+	writel_relaxed(height - 1, vfe->base + VFE_BUS_WM_BUFFER_HEIGHT_CFG(wm));
+	writel_relaxed(0, vfe->base + VFE_BUS_WM_PACKER_CFG(wm));
+	writel_relaxed(stride, vfe->base + VFE_BUS_WM_STRIDE(wm));
+
+	/* QCOM_PLAIN mode for processed pixel data */
+	val = 1 << WM_CFG_EN | MODE_QCOM_PLAIN << WM_CFG_MODE;
+	writel_relaxed(val, vfe->base + VFE_BUS_WM_CFG(wm));
+}
+
+static void vfe_wm_update_pix(struct vfe_device *vfe, u8 wm, u32 addr,
+			      struct vfe_line *line, int plane)
+{
+	struct v4l2_pix_format_mplane *pix =
+		&line->video_out.active_fmt.fmt.pix_mp;
+	u32 stride = pix->plane_fmt[0].bytesperline;
+	u32 height = (plane == 1) ? pix->height / 2 : pix->height;
+
+	writel_relaxed(addr, vfe->base + VFE_BUS_WM_IMAGE_ADDR(wm));
+	writel_relaxed(stride * height, vfe->base + VFE_BUS_WM_FRAME_INC(wm));
+}
