+/*
+ * vfe_pix_configure_isp - Program ISP registers for debayer + YUV pipeline
+ *
+ * Register values derived from openpilot ife.h and downstream register dump.
+ * Programs: demux, white balance, black level, debayer, color correction,
+ * YUV conversion, scaling, cropping, CAMIF, and gamma LUT.
+ */
+static void vfe_pix_configure_isp(struct vfe_device *vfe,
+				   u32 in_w, u32 in_h,
+				   u32 out_w, u32 out_h)
+{
+	/*
+	 * CGC (Clock Gate Control) override registers.
+	 * Force clocks ON for all ISP module groups.
+	 * Without this, ISP modules are clock-gated and produce constant output.
+	 * Values from downstream register dump.
+	 */
+	writel_relaxed(0xffffffff, vfe->base + 0x02c); /* LENS CGC override */
+	writel_relaxed(0xffffffff, vfe->base + 0x030); /* STATS CGC override */
+	writel_relaxed(0xffffffff, vfe->base + 0x034); /* COLOR CGC override */
+	writel_relaxed(0xffffffff, vfe->base + 0x038); /* ZOOM CGC override */
+	writel_relaxed(0xffffffff, vfe->base + 0x03c); /* BUS CGC override */
+
+	/* CORE_CFG: pixel_pattern=1 (GRGRGR), INPUTMUX=CAMIF */
+	writel_relaxed(0x01, vfe->base + VFE_CORE_CFG);
+
+	/*
+	 * Module enables.
+	 * LENS_EN (0x40): BLACK(1) + DEMUX(2) + DEMO(10) + BLACK_LEVEL(11) = 0x0c06
+	 *   Linearization (bit 1) enabled: LUT loaded via DMI below.
+	 * STATS_EN (0x44): none
+	 * COLOR_EN (0x48): COLOR_CORRECT(1) + RGB_LUT(3) = 0x0a
+	 *   RGB_LUT/gamma enabled: LUT loaded via DMI below.
+	 * ZOOM_EN (0x4c): Y_SCALER(0) + UV_SCALER(3) + Y_CROP(4) = 0x19
+	 */
+	writel_relaxed(0x00000c06, vfe->base + VFE_MODULE_EN);
+	writel_relaxed(0x00000000, vfe->base + VFE_MODULE_STATS);
+	writel_relaxed(0x0000000a, vfe->base + VFE_MODULE_COLOR);
+	writel_relaxed(0x00000019, vfe->base + VFE_MODULE_ZOOM);
+	writel_relaxed(0x00000000, vfe->base + VFE_ROUND_CLAMP_CFG);
+
+	/* Demux configuration */
+	writel_relaxed(0x00000001, vfe->base + VFE_DEMUX_CFG + 0x00);
+	writel_relaxed(0x04440444, vfe->base + VFE_DEMUX_CFG + 0x04);
+	writel_relaxed(0x04450445, vfe->base + VFE_DEMUX_CFG + 0x08);
+	writel_relaxed(0x04440444, vfe->base + VFE_DEMUX_CFG + 0x0c);
+	writel_relaxed(0x04450445, vfe->base + VFE_DEMUX_CFG + 0x10);
+	writel_relaxed(0x0000009c, vfe->base + VFE_DEMUX_CFG + 0x14); /* GRBG even */
+	writel_relaxed(0x000000ca, vfe->base + VFE_DEMUX_CFG + 0x18); /* GRBG odd */
+
+	/* White balance: unity (1.0x for all channels) */
+	writel_relaxed(0x00800080, vfe->base + VFE_WB_CFG + 0x00);
+	writel_relaxed(0x00000080, vfe->base + VFE_WB_CFG + 0x04);
+	writel_relaxed(0x00000000, vfe->base + VFE_WB_CFG + 0x08);
+	writel_relaxed(0x00000000, vfe->base + VFE_WB_CFG + 0x0c);
+
+	/* Black level: downstream value (scale=2048, offset=0) */
+	writel_relaxed(0x04000000, vfe->base + VFE_BLC_CFG + 0x00);
+	writel_relaxed(0x00000000, vfe->base + VFE_BLC_CFG + 0x04);
+	writel_relaxed(0x00000000, vfe->base + VFE_BLC_CFG + 0x08);
+
+	/* Debayer: config + all per-direction coefficients from downstream dump */
+	writel_relaxed(0x00000100, vfe->base + VFE_DEMOSAIC_CFG);
+	writel_relaxed(0x00008000, vfe->base + 0x71c);
+	{ int i; for (i = 0; i < 16; i++)
+		writel_relaxed(0x08000066, vfe->base + 0x720 + i * 4);
+	}
+
+	/* Color correction: OX03C10 matrix from openpilot */
+	writel_relaxed(0x000000b6, vfe->base + VFE_CC_CFG + 0x00);
+	writel_relaxed(0x00000ff1, vfe->base + VFE_CC_CFG + 0x04);
+	writel_relaxed(0x00000fda, vfe->base + VFE_CC_CFG + 0x08);
+	writel_relaxed(0x00000fcc, vfe->base + VFE_CC_CFG + 0x0c);
+	writel_relaxed(0x000000b9, vfe->base + VFE_CC_CFG + 0x10);
+	writel_relaxed(0x00000ffb, vfe->base + VFE_CC_CFG + 0x14);
+	writel_relaxed(0x00000fc2, vfe->base + VFE_CC_CFG + 0x18);
+	writel_relaxed(0x00000ff6, vfe->base + VFE_CC_CFG + 0x1c);
+	writel_relaxed(0x000000c9, vfe->base + VFE_CC_CFG + 0x20);
+
+	/* YUV conversion: BT.601 matrix */
+	writel_relaxed(0x00680208, vfe->base + VFE_YUV_CFG + 0x00);
+	writel_relaxed(0x00000108, vfe->base + VFE_YUV_CFG + 0x04);
+	writel_relaxed(0x00400000, vfe->base + VFE_YUV_CFG + 0x08);
+	writel_relaxed(0x03ff0000, vfe->base + VFE_YUV_CFG + 0x0c);
+	writel_relaxed(0x01c01ed8, vfe->base + VFE_YUV_CFG + 0x10);
+	writel_relaxed(0x00001f68, vfe->base + VFE_YUV_CFG + 0x14);
+	writel_relaxed(0x02000000, vfe->base + VFE_YUV_CFG + 0x18);
+	writel_relaxed(0x03ff0000, vfe->base + VFE_YUV_CFG + 0x1c);
+	writel_relaxed(0x1fb81e88, vfe->base + VFE_YUV_CFG + 0x20);
+	writel_relaxed(0x000001c0, vfe->base + VFE_YUV_CFG + 0x24);
+	writel_relaxed(0x02000000, vfe->base + VFE_YUV_CFG + 0x28);
+	writel_relaxed(0x03ff0000, vfe->base + VFE_YUV_CFG + 0x2c);
+
+	/*
+	 * Scaler: match downstream exactly.
+	 * Y: 1928->1928 width, 1208->1208 height (crop metadata lines)
+	 * UV: 1928->964 width (2:1), 1208->604 height (2:1)
+	 * Use hardcoded downstream values for initial bring-up.
+	 */
+	writel_relaxed(0x00000003, vfe->base + VFE_SCALE_Y_CFG + 0x00);
+	writel_relaxed(0x07870787, vfe->base + VFE_SCALE_Y_CFG + 0x04);
+	writel_relaxed(0x30036666, vfe->base + VFE_SCALE_Y_CFG + 0x08);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_Y_CFG + 0x0c);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_Y_CFG + 0x10);
+	writel_relaxed(0x00000787, vfe->base + VFE_SCALE_Y_CFG + 0x14);
+	writel_relaxed(0x04b704b7, vfe->base + VFE_SCALE_Y_CFG + 0x18);
+	writel_relaxed(0x30036666, vfe->base + VFE_SCALE_Y_CFG + 0x1c);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_Y_CFG + 0x20);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_Y_CFG + 0x24);
+	writel_relaxed(0x000004b7, vfe->base + VFE_SCALE_Y_CFG + 0x28);
+
+	writel_relaxed(0x00000003, vfe->base + VFE_SCALE_UV_CFG + 0x00);
+	writel_relaxed(0x03c30787, vfe->base + VFE_SCALE_UV_CFG + 0x04);
+	writel_relaxed(0x3006cccc, vfe->base + VFE_SCALE_UV_CFG + 0x08);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_UV_CFG + 0x0c);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_UV_CFG + 0x10);
+	writel_relaxed(0x00000787, vfe->base + VFE_SCALE_UV_CFG + 0x14);
+	writel_relaxed(0x025b04b7, vfe->base + VFE_SCALE_UV_CFG + 0x18);
+	writel_relaxed(0x3006cccc, vfe->base + VFE_SCALE_UV_CFG + 0x1c);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_UV_CFG + 0x20);
+	writel_relaxed(0x00000000, vfe->base + VFE_SCALE_UV_CFG + 0x24);
+	writel_relaxed(0x000004b7, vfe->base + VFE_SCALE_UV_CFG + 0x28);
+
+	/* Y crop */
+	/* Y crop: match downstream exactly */
+	writel_relaxed(0x00000e00, vfe->base + VFE_CROP_Y_WIDTH);
+	writel_relaxed(0x000004b7, vfe->base + VFE_CROP_Y_HEIGHT);   /* 1207 = 1208-1 */
+	writel_relaxed(0x00000787, vfe->base + VFE_CROP_Y_WIDTH_OUT); /* 1927 = 1928-1 */
+	writel_relaxed(0x0ff00000, vfe->base + VFE_CROP_Y_RND + 0x00);
+	writel_relaxed(0x00000016, vfe->base + VFE_CROP_Y_RND + 0x04);
+
+	/* UV crop: match downstream exactly */
+	writel_relaxed(0x00000e00, vfe->base + VFE_CROP_UV_WIDTH);
+	writel_relaxed(0x0000025b, vfe->base + VFE_CROP_UV_HEIGHT);   /* 603 = 604-1 */
+	writel_relaxed(0x00000787, vfe->base + VFE_CROP_UV_WIDTH_OUT); /* 1927 = 1928-1 */
+	writel_relaxed(0x0ff00000, vfe->base + VFE_CROP_UV_RND + 0x00);
+	writel_relaxed(0x00000017, vfe->base + VFE_CROP_UV_RND + 0x04);
+
+	/* CAMIF: clear status + enable output
+	 * Downstream value: 0x004000c0 = raw_crop_en | vfe_output_en | bus_output_en
+	 */
+	writel_relaxed(CMD_CLEAR_CAMIF_STATUS, vfe->base + VFE_CAMIF_CMD);
+	writel_relaxed(CFG_RAW_CROP_EN | CFG_VFE_OUTPUT_EN | CFG_BUS_OUTPUT_EN,
+		       vfe->base + VFE_CAMIF_CFG);
+
+	/* CAMIF subsample and skip (from openpilot ife.h offsets 0x488-0x49c) */
+	writel_relaxed(0x00000000, vfe->base + 0x488);
+	writel_relaxed(0x00000000, vfe->base + 0x48c);
+	writel_relaxed(0x00000f0f, vfe->base + 0x490);
+	writel_relaxed(0x00000001, vfe->base + 0x49c);
+
+	/* Epoch IRQ: half frame */
+	writel_relaxed(((in_h / 2) << 16) | 0x14, vfe->base + VFE_EPOCH_IRQ);
+
+	/* ISP flush/halt config (from downstream dump + camx FillFlushConfig) */
+	writel_relaxed(0x01010000, vfe->base + 0xf80);
+	writel_relaxed(0x01010000, vfe->base + 0xf84);
+	writel_relaxed(0x01010000, vfe->base + 0xf88);
+	writel_relaxed(0x01010000, vfe->base + 0xf8c);
+
+	/* Dual PD CGC override (from camx FillCGCConfig) */
+	writel_relaxed(0x00000001, vfe->base + 0xfac);
+
+	/* CAMIF raw crop: full frame (RAW_CROP_EN is set in CAMIF_CFG bit 22) */
+	writel_relaxed(in_w - 1, vfe->base + 0xce4);         /* last_pixel */
+	writel_relaxed(in_h - 1, vfe->base + 0xce8);         /* last_line */
+
+	/* Linearization: kneepoints + LUT via DMI (matching openpilot) */
+	writel_relaxed(0x00000000, vfe->base + VFE_LINEAR_CFG); /* BANK0 */
+	{ int i;
+	  for (i = 0; i < 4; i++) {
+		writel_relaxed(ox03c10_linear_pts[i],
+			       vfe->base + VFE_LINEAR_INTERP_R + i * 4);
+		writel_relaxed(ox03c10_linear_pts[i],
+			       vfe->base + VFE_LINEAR_INTERP_GB + i * 4);
+		writel_relaxed(ox03c10_linear_pts[i],
+			       vfe->base + VFE_LINEAR_INTERP_B + i * 4);
+		writel_relaxed(ox03c10_linear_pts[i],
+			       vfe->base + VFE_LINEAR_INTERP_GR + i * 4);
+	  }
+	}
+	vfe_dmi_upload_lut(vfe, DMI_RAM_SEL_BLACK_LUT_BANK0,
+			   ox03c10_linear_lut, ARRAY_SIZE(ox03c10_linear_lut));
+
+	/* Gamma LUT: upload OX03C10 curve to all 3 channels via DMI */
+	vfe_dmi_upload_lut(vfe, DMI_RAM_SEL_GLUT_CH0_BANK0,
+			   ox03c10_gamma_lut, ARRAY_SIZE(ox03c10_gamma_lut));
+	vfe_dmi_upload_lut(vfe, DMI_RAM_SEL_GLUT_CH1_BANK0,
+			   ox03c10_gamma_lut, ARRAY_SIZE(ox03c10_gamma_lut));
+	vfe_dmi_upload_lut(vfe, DMI_RAM_SEL_GLUT_CH2_BANK0,
+			   ox03c10_gamma_lut, ARRAY_SIZE(ox03c10_gamma_lut));
+	writel_relaxed(0x00000000, vfe->base + VFE_GAMMA_CFG); /* all ch bank 0 */
+
+	/* Ensure all register writes complete before reg_update */
+	wmb();
+}
